[
  // Alias space → cmd-space in vim normal mode so the universal leader bindings work
  // (also prevents vim::WrappingRight from conflicting with which-key)
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space": ["workspace::SendKeystrokes", "cmd-space"],
    },
  },

  // ==================================================================================
  // Vim-specific bindings (g* motions, LSP, diagnostics — only meaningful in editor)
  // ==================================================================================
  {
    "context": "vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      // Code / LSP Navigation
      "g d": "editor::GoToDefinition",
      "g r": "editor::FindAllReferences",
      "g I": "editor::GoToImplementation",
      "g t": "editor::GoToTypeDefinition",
      "g D": "editor::GoToDeclaration",
      "shift-k": "editor::Hover",

      // Diagnostics navigation
      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic",

      // Quick toggles (no leader)
      "ctrl-,": "workspace::ToggleBottomDock",
      "ctrl-n": "pane::RevealInProjectPanel",
    },
  },

  // ==================================================================================
  // Universal leader bindings (cmd-space)
  // In vim normal mode, bare "space" aliases to "cmd-space" (see above),
  // so these work as "space ..." from the editor and "cmd-space ..." from anywhere.
  // ==================================================================================
  {
    "context": "Workspace",
    "bindings": {
      "cmd-;": "command_palette::Toggle",

      // Splits & window management
      "cmd-space w s": "pane::SplitDown",
      "cmd-space w v": "pane::SplitRight",
      "cmd-space w d": "pane::CloseActiveItem",

      // Code actions (editor-specific, but harmless from other contexts)
      "cmd-space c r": "editor::Rename",
      "cmd-space c a": "editor::ToggleCodeActions",
      "cmd-space c f": "editor::Format",
      "cmd-space c o": "outline::Toggle",

      // Buffer path
      "cmd-space b y": "workspace::CopyRelativePath",
      "cmd-space b shift-y": "workspace::CopyPath",

      // Diagnostics panel
      "cmd-space d d": "diagnostics::Deploy",

      // Search / Fuzzy Finding
      "cmd-space s f": "file_finder::Toggle",
      "cmd-space s g": "pane::DeploySearch",
      "cmd-space /": ["buffer_search::Deploy", { "focus": true }],
      "cmd-space space": "tab_switcher::ToggleAll",

      // File Explorer
      "cmd-space e": "project_panel::ToggleFocus",

      // Git
      "cmd-space g g": "git_panel::ToggleFocus",
      "cmd-space g b": "git::Branch",

      // AI assistant
      "cmd-space a a": "agent::ToggleFocus",
      "cmd-space a t": "multi_workspace::ToggleWorkspaceSidebar", // [t]hreads sidebar
      "cmd-space a s": "agents_sidebar::ToggleThreadSwitcher", // thread [s]witcher

      // Terminal
      "cmd-space t t": "terminal_panel::ToggleFocus",
      "cmd-space t h": "workspace::ToggleBottomDock",
      "cmd-space t f": "workspace::NewCenterTerminal",
      "cmd-space t n": "workspace::NewTerminal",
      "cmd-space t r": "terminal::RenameTerminal",
    },
  },
  // cmd-; needs to override the default line-number toggle in Editor context
  {
    "context": "Editor",
    "bindings": {
      "cmd-;": "command_palette::Toggle",
    },
  },

  // ==================================================================================
  // Pane navigation, resizing, and tab management
  //
  // Scheme:
  //   ctrl-hjkl         → move focus among panes
  //   ctrl-arrows        → resize panes
  //   ctrl-shift-hjkl    → move tab to pane in direction
  //   ctrl-{ / ctrl-}    → reorder tab within pane
  //
  // The Workspace baseline below covers everything except Editor and Terminal.
  // Excluded because:
  //   - Editor in insert mode would lose vim's ctrl-h-as-backspace convention,
  //     and the vim normal mode block handles editor pane nav properly
  //   - Terminal forwards raw keys to the PTY and needs explicit re-binding
  //     (and uses vim::ResizePane* directly because SendKeystrokes is eaten)
  // ==================================================================================

  // --- Workspace baseline (catches Markdown preview, SVG, CSV, image,
  //     project/git panels, project search results, git diffs, etc.,
  //     PLUS editors in vim normal mode) ---
  {
    "context": "(Workspace && !Editor) || (vim_mode == normal && !VimWaiting && !menu)",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-left": ["workspace::SendKeystrokes", "1 0 ctrl-w <"],
      "ctrl-right": ["workspace::SendKeystrokes", "1 0 ctrl-w >"],
      "ctrl-down": ["workspace::SendKeystrokes", "5 ctrl-w -"],
      "ctrl-up": ["workspace::SendKeystrokes", "5 ctrl-w +"],
      "ctrl-shift-h": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "left" },
      ],
      "ctrl-shift-l": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "right" },
      ],
      "ctrl-shift-j": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "down" },
      ],
      "ctrl-shift-k": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "up" },
      ],
      "ctrl-{": "pane::SwapItemLeft",
      "ctrl-}": "pane::SwapItemRight",
    },
  },

  // --- Terminal ---
  // Workspace baseline now applies in Terminal too (no `!Terminal` exclusion).
  // We only override the bindings that need PTY-aware treatment:
  //   - ctrl-hjkl: Terminal otherwise forwards as control chars
  //   - ctrl-arrows: Terminal eats SendKeystrokes, so use vim::ResizePane* directly
  // ctrl-shift-hjkl and ctrl-{/} are served by Workspace baseline.
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-left": "vim::ResizePaneLeft",
      "ctrl-right": "vim::ResizePaneRight",
      "ctrl-down": "vim::ResizePaneDown",
      "ctrl-up": "vim::ResizePaneUp",
      // Redundant with Workspace baseline above; uncomment if regression observed.
      // "ctrl-shift-h": ["workspace::MoveItemToPaneInDirection", { "direction": "left" }],
      // "ctrl-shift-l": ["workspace::MoveItemToPaneInDirection", { "direction": "right" }],
      // "ctrl-shift-j": ["workspace::MoveItemToPaneInDirection", { "direction": "down" }],
      // "ctrl-shift-k": ["workspace::MoveItemToPaneInDirection", { "direction": "up" }],
      // "ctrl-{": "pane::SwapItemLeft",
      // "ctrl-}": "pane::SwapItemRight",
      "ctrl-space": "terminal::ToggleViMode",
    },
  },

  // --- Project panel ---
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "q": "workspace::ToggleLeftDock",
    },
  },

  // --- Git panel ---
  {
    "context": "GitPanel",
    "bindings": {
      "h": ["workspace::SendKeystrokes", "left"],
      "l": ["workspace::SendKeystrokes", "right"],
      "q": "workspace::ToggleLeftDock",
    },
  },

  // ==================================================================================
  // Agent panel (ACP threads — i.e. claude-acp via agent_servers)
  //
  // Strategy: scroll the conversation directly via the agent::ScrollOutput*
  // actions, which Zed handles in BOTH the AcpThread (conversation pane) and
  // its Editor child (composer). So you don't have to change focus to scroll
  // — the thread scrolls underneath while you keep typing.
  //
  // Context inheritance: parent bindings DO propagate to children unless
  // overridden. So bare keys (j/k/[[/etc.) bound on plain `AcpThread` would
  // hijack typing in the composer. They go on `AcpThread && !Editor` so they
  // only fire when the conversation pane is focused. Modifier-keyed
  // bindings can stay on bare `AcpThread` — they don't conflict with typing
  // and we want them inherited by the composer (one binding works from both).
  //
  // Note: agent::FocusUp/Down/Left/Right are declared in the agent_ui crate
  // but never wired to handlers. Bindings to them silently no-op. Don't use.
  // ==================================================================================

  // Modifier-keyed scroll/exit on the conversation pane. Most are inherited
  // by the composer, but Editor binds ctrl-d (Delete) by default so we have
  // to re-bind on AcpThread > Editor below to override.
  {
    "context": "AcpThread",
    "bindings": {
      "ctrl-u": "agent::ScrollOutputPageUp",
      "ctrl-d": "agent::ScrollOutputPageDown",
      "ctrl-y": "agent::ScrollOutputLineUp",
      "ctrl-e": "agent::ScrollOutputLineDown",
      "ctrl-shift-u": "agent::ScrollOutputToTop",
      "ctrl-shift-d": "agent::ScrollOutputToBottom",
      "ctrl-{": "agent::ScrollOutputToPreviousMessage",
      "ctrl-}": "agent::ScrollOutputToNextMessage",
      "ctrl-j": "agent::ToggleFocus", // Gets you back into the editor
    },
  },

  // Composer overrides — bindings the parent AcpThread loses to in this context.
  // Why each one needs an explicit re-bind:
  //   - ctrl-d   → Editor default: editor::Delete
  //   - ctrl-y   → Editor default: editor::KillRingYank
  //   - ctrl-e   → Editor default: editor::MoveToEndOfLine
  //   - ctrl-u   → vim default: editor::DeleteToBeginningOfLine (insert mode)
  //   - ctrl-shift-d → Zed default in AcpThread > Editor itself: git::Diff
  //   - ctrl-h   → vim insert default: editor::Backspace
  //   - ctrl-j   → vim insert default: editor::Newline
  //   - ctrl-k   → vim insert default: digraph prefix (no-op in Zed, but not pane nav)
  //   - ctrl-l   → workspace baseline excludes Editor, so insert mode never sees pane nav
  // ctrl-shift-u inherits cleanly (no conflicting default).
  {
    "context": "AcpThread > Editor",
    "bindings": {
      "ctrl-u": "agent::ScrollOutputPageUp",
      "ctrl-d": "agent::ScrollOutputPageDown",
      "ctrl-y": "agent::ScrollOutputLineUp",
      "ctrl-e": "agent::ScrollOutputLineDown",
      "ctrl-shift-d": "agent::ScrollOutputToBottom",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
    },
  },
]
